# Copy to .env.local for local development (never commit secrets).

# App URL for Playwright E2E (default http://localhost:5173)
# E2E_BASE_URL=http://localhost:5173

# Set automatically to expose __MAHASEB_E2E__ hooks when Playwright starts the dev server
# VITE_E2E=1

# Optional cloud login E2E (leave unset to skip cloud login tests)
# E2E_LOGIN_EMAIL=
# E2E_LOGIN_PASSWORD=

# Optional signup E2E (leave unset to skip signup flow)
# E2E_SIGNUP_PASSWORD=

# Supabase (both required if either is set — validated in dev)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Optional monitoring
# VITE_SENTRY_DSN=
